# ─────────────────────────────────────────────────────────────
# Production environment for React (Option A — served by Express)
# ─────────────────────────────────────────────────────────────
# Leave VITE_API_URL empty.
# The frontend is served by the same Express server that handles /api/*
# so all fetch('/api/...') calls are automatically same-origin.
# No CORS, no absolute URL needed.
VITE_API_URL=
