# ─────────────────────────────────────────────────────────────
# Backend — local development environment
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# ALLOWED_ORIGINS — only needed if you have other services calling
# this backend (e.g. the Worker container). Not needed for browser
# calls because the frontend is served from this same Express server.
# ALLOWED_ORIGINS=http://localhost:3001

# AWS
AWS_REGION=ap-south-1
S3_BUCKET_NAME=legal-audit-platform-989615686095

# Redis (BullMQ queue)
# REDIS_URL=rediss://default:your_password@your-redis-host:6379

# Anthropic Claude API (via AWS Bedrock in production)
# ANTHROPIC_API_KEY=sk-ant-api...

# Super Admin
SUPER_ADMIN_EMAIL=nilesh@acc.com
